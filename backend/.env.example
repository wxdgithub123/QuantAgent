# ==========================================
# QuantAgent OS - Backend Environment Configuration
# 后端环境配置模板
# ==========================================
# 使用说明：复制此文件为 .env 并填入实际值
# Usage: Copy this file to .env and fill in actual values

# ──────────────────────────────────────────
# 1. Application Settings | 应用基础配置
# ─────────────────────────────────────────-

# Application Name | 应用名称
APP_NAME=QuantAgent OS

# Debug Mode | 调试模式 (true/false)
# 生产环境必须设为 false
DEBUG=true

# Server Host | 服务器监听地址
# 0.0.0.0 表示监听所有接口，本地开发可用 127.0.0.1
HOST=0.0.0.0

# Server Port | 服务器端口
PORT=8002


# ──────────────────────────────────────────
# 2. Database Configuration | 数据库配置
# ─────────────────────────────────────────-

# PostgreSQL Connection URL | PostgreSQL 连接字符串
# 格式: postgresql+asyncpg://user:password@host:port/database
# 必填 | Required
DATABASE_URL=postgresql+asyncpg://quantagent:quantagent@localhost:5435/quantagent


# ──────────────────────────────────────────
# 3. Cache Configuration | 缓存配置
# ─────────────────────────────────────────-

# Redis Connection URL | Redis 连接字符串
# 格式: redis://host:port/db
# 必填 | Required
REDIS_URL=redis://localhost:6382/0


# ──────────────────────────────────────────
# 4. Message Queue | 消息队列配置
# ─────────────────────────────────────────-

# NATS Connection URL | NATS 消息队列连接地址
# 必填 | Required
NATS_URL=nats://localhost:4223


# ──────────────────────────────────────────
# 5. Time-Series Database | 时序数据库配置
# ─────────────────────────────────────────-

# ClickHouse HTTP Port | ClickHouse HTTP 端口
# 用于数据分析和高性能查询
# 必填 | Required
CLICKHOUSE_PORT=8124

# ClickHouse Host | ClickHouse 主机地址
# Docker 环境下为 clickhouse，本地开发使用 localhost
# 必填 | Required
CLICKHOUSE_HOST=localhost

# ClickHouse Database | ClickHouse 数据库名称
# 必填 | Required
CLICKHOUSE_DB=quantagent


# ──────────────────────────────────────────
# 6. Authentication | 身份认证配置
# ─────────────────────────────────────────-

# JWT Secret Key | JWT 密钥
# ⚠️ 必填，生产环境必须使用强随机字符串
# ⚠️ Required, use strong random string in production
SECRET_KEY=your-super-secret-key-change-this-in-production

# Access Token Expiration | 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30


# ──────────────────────────────────────────
# 7. CORS Configuration | 跨域配置
# ─────────────────────────────────────────-

# Allowed CORS Origins | 允许的跨域来源
# JSON 数组格式，包含前端地址
# 必填 | Required
CORS_ORIGINS=["http://localhost:3002","http://127.0.0.1:3002"]


# ──────────────────────────────────────────
# 8. Exchange API Keys | 交易所 API 配置
# ─────────────────────────────────────────-

# Binance API Key | 币安 API 密钥
# 用于获取行情数据和执行交易
# 可选，但交易功能需要 | Optional, required for trading
BINANCE_API_KEY=your_binance_api_key_here

# Binance Secret Key | 币安 API 密钥（HMAC 认证）
# 可选，与 API Key 配合使用的 HMAC 认证方式；如使用 RSA 认证则配置 BINANCE_PRIVATE_KEY_PATH
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Binance Private Key Path | 币安私钥文件路径
# 用于 RSA 签名认证
# 可选 | Optional
BINANCE_PRIVATE_KEY_PATH=/app/Private_key.pem

# CoinGecko API Key | CoinGecko API 密钥
# 用于获取加密货币价格数据
# 可选 | Optional
COINGECKO_API_KEY=your_coingecko_api_key_here


# ──────────────────────────────────────────
# 9. Proxy Settings | 代理配置
# ─────────────────────────────────────────-

# HTTP/HTTPS Proxy | HTTP/HTTPS 代理
# 在受限地区访问 Binance 等服务时使用
# 可选 | Optional
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897


# ──────────────────────────────────────────
# 10. AI/LLM Configuration | AI/LLM 配置
# ─────────────────────────────────────────-

# LLM Provider | LLM 提供商
# 可选值: ollama, openai, openrouter
# 必填 | Required
LLM_PROVIDER=openai

# ── OpenAI Compatible API | OpenAI 兼容 API ──
# 支持阿里云 DashScope、OpenAI 官方等

# OpenAI API Key | API 密钥
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Base URL | API 基础地址
# 阿里云: https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI Model | 模型名称
# 阿里云: qwen3-max, qwen3-235b-a22b
# OpenAI: gpt-4, gpt-3.5-turbo
OPENAI_MODEL=qwen3-max

# ── Ollama Local LLM | Ollama 本地模型 ──

# Ollama Base URL | Ollama 服务地址
# Docker 内使用 host-gateway，本地开发使用 127.0.0.1
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Ollama Model | 模型名称
OLLAMA_MODEL=qwen3:8b

# Disable Proxy for Ollama | 禁用 Ollama 代理
# 确保本地直连，避免代理干扰
OLLAMA_NO_PROXY=true

# ── Embedding Configuration | 向量嵌入配置 ──

# Embedding Provider | 嵌入提供商
# 可选值: ollama, openai
EMBEDDING_PROVIDER=ollama

# Embedding Model | 嵌入模型
EMBEDDING_MODEL=qwen3:8b
